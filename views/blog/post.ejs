<%- include('../partials/header') %>

<div class="blog-post-page">
    <div class="container">
        <!-- Breadcrumb -->
        <nav class="breadcrumb" aria-label="Breadcrumb">
            <a href="/">Home</a>
            <span class="breadcrumb-sep">›</span>
            <a href="/blog">Blog</a>
            <span class="breadcrumb-sep">›</span>
            <span class="breadcrumb-current"><%= blog.title %></span>
        </nav>

        <div class="blog-post-layout">
            <main class="blog-post-main">
                <article class="blog-article">
                    <div class="blog-post-meta">
                        <span class="blog-category"><%= blog.category %></span>
                        <time datetime="<%= blog.datePublished %>">
                            <%= new Date(blog.datePublished).toLocaleDateString('en-IN', { year: 'numeric', month: 'long', day: 'numeric' }) %>
                        </time>
                    </div>

                    <h1><%= blog.title %></h1>

                    <% if (blog.relatedCalculator) { %>
                    <div class="blog-cta-box">
                        <span>⚡ Skip the math —</span>
                        <a href="/calculator/<%= blog.relatedCalculator.slug %>" class="btn">Use the Free <%= blog.relatedCalculator.title %> →</a>
                    </div>
                    <% } %>

                    <!-- Blog Content -->
                    <div class="blog-content">
                        <% if (contentExists) { %>
                            <%- include('./posts/' + contentSlug) %>
                        <% } else { %>
                            <p>Full article coming soon. In the meantime, use our <a href="/calculator/<%= blog.relatedCalculator ? blog.relatedCalculator.slug : '' %>">free calculator</a>.</p>
                        <% } %>
                    </div>

                    <% if (blog.relatedCalculator) { %>
                    <div class="blog-cta-box blog-cta-bottom">
                        <h3>Try it yourself — Free & Instant</h3>
                        <p>No signup required. Results in seconds.</p>
                        <a href="/calculator/<%= blog.relatedCalculator.slug %>" class="btn btn-large">Open <%= blog.relatedCalculator.title %> →</a>
                    </div>
                    <% } %>
                </article>
            </main>

            <aside class="blog-sidebar">
                <div class="sidebar-box">
                    <h3>📚 More Guides</h3>
                    <ul class="sidebar-links">
                        <li><a href="/blog/how-to-calculate-emi-manually">How to Calculate EMI</a></li>
                        <li><a href="/blog/how-to-calculate-gst-in-india">How to Calculate GST</a></li>
                        <li><a href="/blog/how-to-calculate-profit-margin">How to Calculate Profit Margin</a></li>
                        <li><a href="/blog/percentage-formula-explained">Percentage Formula Explained</a></li>
                        <li><a href="/blog/compound-interest-formula-explained">Compound Interest Formula</a></li>
                        <li><a href="/blog">View All Guides →</a></li>
                    </ul>
                </div>
                <div class="sidebar-box">
                    <h3>🔢 Popular Calculators</h3>
                    <ul class="sidebar-links">
                        <li><a href="/calculator/emi-calculator">EMI Calculator</a></li>
                        <li><a href="/calculator/gst-calculator">GST Calculator</a></li>
                        <li><a href="/calculator/bmi-calculator">BMI Calculator</a></li>
                        <li><a href="/calculator/sip-calculator">SIP Calculator</a></li>
                        <li><a href="/calculator/percentage-calculator">Percentage Calculator</a></li>
                    </ul>
                </div>
            </aside>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>
