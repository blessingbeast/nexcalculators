    <tr style="background:#4f46e5;color:white;"><th style="padding:10px;text-align:left;">Feature</th><th style="padding:10px;text-align:left;">Simple Interest</th><th style="padding:10px;text-align:left;">Compound Interest</th></tr>
    <tr style="background:#f8f9fa;"><td style="padding:10px;">Calculation basis</td><td style="padding:10px;">Only principal</td><td style="padding:10px;">Principal + accumulated interest</td></tr>
