<%- include('partials/header') %>

    <div class="container" style="padding-top: 30px; padding-bottom: 60px;">

        <!-- Breadcrumb -->
        <nav class="breadcrumb" aria-label="Breadcrumb">
            <a href="/">Home</a>
            <span class="breadcrumb-sep">›</span>
            <span class="breadcrumb-current">All Calculators</span>
        </nav>

        <h1 style="margin-bottom: 8px;">All Free Online Calculators</h1>
        <p style="color: var(--text-secondary); margin-bottom: 40px; font-size: 1.1rem;">
            Browse our complete collection of <%= calculators.length %>+ free calculators for finance, health, math, and more.
        </p>

        <!-- ItemList Structured Data -->
        <script type="application/ld+json">
        {
          "@context": "https://schema.org",
          "@type": "ItemList",
          "name": "Free Online Calculators – NexCalculators",
          "description": "Browse 60+ free online calculators for finance, health, math, and more.",
          "url": "<%= (typeof baseUrl !== 'undefined' ? baseUrl : 'https://www.nexcalculators.com') %>/calculators",
          "numberOfItems": <%= calculators.length %>,
          "itemListElement": [
            <% calculators.forEach(function(calc, index) { %>
            {
              "@type": "ListItem",
              "position": <%= index + 1 %>,
              "name": <%- JSON.stringify(calc.title) %>,
              "url": "<%= (typeof baseUrl !== 'undefined' ? baseUrl : 'https://www.nexcalculators.com') %>/calculator/<%= calc.slug %>"
            }<%= index < calculators.length - 1 ? ',' : '' %>
            <% }); %>
          ]
        }
        </script>

        <% 
            const grouped = {};
            calculators.forEach(calc => {
                const cat = calc.category || 'Other';
                if (!grouped[cat]) grouped[cat] = [];
                grouped[cat].push(calc);
            });
            const categoryOrder = ['Financial', 'Math', 'Health', 'Work & Salary', 'Daily Utilities'];
            const categoryIcons = {
                'Financial':      '💰',
                'Health':         '🏥',
                'Math':           '🔢',
                'Work & Salary':  '💼',
                'Daily Utilities':'🚗',
                'Other':          '📊'
            };
        %>

        <!-- Quick Jump Category Nav -->
        <nav class="category-jump-nav" aria-label="Jump to category">
            <% categoryOrder.forEach(function(cat) { %>
                <% if (grouped[cat] && grouped[cat].length > 0) { %>
                <a href="#<%= cat.replace(/\s+/g, '-') %>" class="category-jump-btn">
                    <%= categoryIcons[cat] || '📊' %> <%= cat %>
                    <span class="jump-count"><%= grouped[cat].length %></span>
                </a>
                <% } %>
            <% }); %>
            <% Object.keys(grouped).sort().forEach(function(cat) { %>
                <% if (!categoryOrder.includes(cat)) { %>
                <a href="#<%= cat.replace(/\s+/g, '-') %>" class="category-jump-btn">
                    <%= categoryIcons[cat] || '📊' %> <%= cat %>
                    <span class="jump-count"><%= grouped[cat].length %></span>
                </a>
                <% } %>
            <% }); %>
        </nav>

        <!-- Render all categories in order -->
        <% categoryOrder.forEach(function(cat) { %>
            <% if (grouped[cat] && grouped[cat].length > 0) { %>
            <section class="calc-dir-section" id="<%= cat.replace(/\s+/g, '-') %>">
                <h2 class="calc-dir-heading">
                    <%= categoryIcons[cat] || '📊' %> <%= cat %> Calculators
                    <span class="category-count">(<%= grouped[cat].length %>)</span>
                </h2>
                <div class="calc-dir-grid">
                    <% grouped[cat].forEach(function(calc) { %>
                    <a href="/calculator/<%= calc.slug %>" class="calc-dir-card">
                        <span class="calc-dir-name"><%= calc.title %></span>
                        <span class="calc-dir-desc"><%= calc.metaDescription ? calc.metaDescription.substring(0, 90) + '...' : 'Free online calculator.' %></span>
                    </a>
                    <% }); %>
                </div>
            </section>
            <% } %>
        <% }); %>

        <!-- Render any remaining categories not in the ordered list -->
        <% Object.keys(grouped).sort().forEach(function(cat) { %>
            <% if (!categoryOrder.includes(cat) && grouped[cat].length > 0) { %>
            <section class="calc-dir-section" id="<%= cat.replace(/\s+/g, '-') %>">
                <h2 class="calc-dir-heading">
                    <%= categoryIcons[cat] || '📊' %> <%= cat %> Calculators
                    <span class="category-count">(<%= grouped[cat].length %>)</span>
                </h2>
                <div class="calc-dir-grid">
                    <% grouped[cat].forEach(function(calc) { %>
                    <a href="/calculator/<%= calc.slug %>" class="calc-dir-card">
                        <span class="calc-dir-name"><%= calc.title %></span>
                        <span class="calc-dir-desc"><%= calc.metaDescription ? calc.metaDescription.substring(0, 90) + '...' : 'Free online calculator.' %></span>
                    </a>
                    <% }); %>
                </div>
            </section>
            <% } %>
        <% }); %>
    </div>

<%- include('partials/footer') %>
