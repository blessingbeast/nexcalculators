<%- include('partials/header') %>

    <section class="hero">
        <div class="container">
            <h1>Free Online Calculators</h1>
            <p>Quick, accurate, and easy-to-use calculators for finance, health, math, and more. Designed for
                professionals and students alike.</p>
        </div>
    </section>

    <!-- Popular Calculators Section -->
    <div class="container">
        <h2 class="category-title">
            <span class="category-icon">⭐</span> Popular Calculators
        </h2>
        <div class="calculator-grid popular-grid">
            <a href="/calculator/emi-calculator" class="popular-card">
                <span class="popular-icon">💳</span>
                <strong>EMI Calculator</strong>
                <span>Calculate loan EMI instantly</span>
            </a>
            <a href="/calculator/bmi-calculator" class="popular-card">
                <span class="popular-icon">⚖️</span>
                <strong>BMI Calculator</strong>
                <span>Check your Body Mass Index</span>
            </a>
            <a href="/calculator/age-calculator" class="popular-card">
                <span class="popular-icon">🎂</span>
                <strong>Age Calculator</strong>
                <span>Find exact age in years, months & days</span>
            </a>
            <a href="/calculator/sip-calculator" class="popular-card">
                <span class="popular-icon">📈</span>
                <strong>SIP Calculator</strong>
                <span>Project your mutual fund returns</span>
            </a>
            <a href="/calculator/gst-calculator" class="popular-card">
                <span class="popular-icon">🧾</span>
                <strong>GST Calculator</strong>
                <span>Find GST inclusive & exclusive prices</span>
            </a>
            <a href="/calculator/percentage-calculator" class="popular-card">
                <span class="popular-icon">%</span>
                <strong>Percentage Calculator</strong>
                <span>Fast percentage finder tool</span>
            </a>
        </div>
    </div>

    <!-- Most Used Calculators – SEO Internal Linking Section -->
    <div class="container">
        <section class="most-used-section">
            <h2 class="category-title">
                <span class="category-icon">🔥</span> Most Used Calculators
            </h2>
            <p class="most-used-subtitle">The tools our users open most often — fast, free, accurate.</p>
            <ul class="most-used-list">
                <li><a href="/calculator/emi-calculator">💳 EMI Calculator</a> — Calculate loan EMI instantly</li>
                <li><a href="/calculator/bmi-calculator">⚖️ BMI Calculator</a> — Check your Body Mass Index</li>
                <li><a href="/calculator/gst-calculator">🧾 GST Calculator</a> — GST inclusive & exclusive amounts</li>
                <li><a href="/calculator/age-calculator">🎂 Age Calculator</a> — Exact age in years, months & days</li>
                <li><a href="/calculator/compound-interest-calculator">📈 Compound Interest Calculator</a> — See how money grows</li>
                <li><a href="/calculator/percentage-calculator">% Percentage Calculator</a> — Fast percentage finder</li>
                <li><a href="/calculator/sip-calculator">💰 SIP Calculator (Lumpsum)</a> — Project mutual fund returns</li>
                <li><a href="/calculator/take-home-salary-calculator">💼 Take Home Salary Calculator</a> — India net salary calculator</li>
            </ul>
            <p><a href="/calculators" class="browse-all-link">Browse all <%= calculators.length %>+ free calculators →</a></p>
        </section>
    </div>

    <!-- All Calculators by Category -->
    <div class="container">
        <% const categories={}; calculators.forEach(calc=> {
            const cat = calc.category || 'Other';
            if (!categories[cat]) categories[cat] = [];
            categories[cat].push(calc);
            });
            %>

            <% for (const [category, calcs] of Object.entries(categories)) { %>
                <h2 id="<%= category %>" class="category-title">
                    <span class="category-icon">🔹</span>
                    <%= category %> Calculators
                </h2>
                <div class="calculator-grid">
                    <% calcs.forEach(function(calc) { %>
                        <div class="card">
                            <h3>
                                <%= calc.title %>
                            </h3>
                            <p>
                                <%= calc.metaDescription %>
                            </p>
                            <a href="/calculator/<%= calc.slug %>" class="btn">Use Calculator →</a>
                        </div>
                        <% }); %>
                </div>
                <% } %>
    </div>

<%- include('partials/footer') %>